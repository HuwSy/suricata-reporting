#!/bin/bash

FAST_LOG="/var/log/suricata/fast.log"
HOST_IP=$(hostname -I | awk '{print $1}')
DB="/var/lib/suricata-allowed-dns.db"

declare -A IP_TO_DOMAIN
ALLOWED_IPS=""

# -----------------------------
# Load DNS DB
# -----------------------------
if [[ -s "$DB" ]]; then
    while IFS='|' read -r host flag ip start expiry expired; do
        [[ -z "$host" ]] && continue
        [[ "$ip" == "$HOST_IP" ]] && continue

        if [[ "$flag" = "1" ]]; then
            ALLOWED_IPS+="$ip"$'\n'
        else
            IP_TO_DOMAIN["$ip"]="$host"
        fi
    done < "$DB"
fi

# -----------------------------
# Read + truncate fast.log safely
# -----------------------------
FAST_CONTENT=""
if [[ -s "$FAST_LOG" ]]; then
    FAST_CONTENT=$(<"$FAST_LOG")
    : > "$FAST_LOG"
    printf "%s\n" "$FAST_CONTENT" >> "$FAST_LOG.old"
fi

# -----------------------------
# Filter allowed IPs
# -----------------------------
DNS_IPS=$(printf "%s" "$ALLOWED_IPS" | mawk 'NF' | sort -u)

REPORT=$(printf "%s\n" "$FAST_CONTENT" \
| mawk -v allowed="$DNS_IPS" '
    BEGIN {
        n = split(allowed, a, "\n")
        for (i=1;i<=n;i++) allow[a[i]]=1
    }
    {
        skip=0
        for (ip in allow) if (ip != "" && index($0, ip)) skip=1
        if (!skip) print
    }
')

# -----------------------------
# Build IP→domain map for mawk
# -----------------------------
TMPMAP=$(mktemp)
for ip in "${!IP_TO_DOMAIN[@]}"; do
    printf "%s %s\n" "$ip" "${IP_TO_DOMAIN[$ip]}"
done > "$TMPMAP"

# -----------------------------
# Annotate + signatures + external summary
# -----------------------------
ANNOTATED=$(mktemp)
SIGS=$(mktemp)
DST=$(mktemp)

printf "%s\n" "$REPORT" \
| mawk -v map="$TMPMAP" '
    BEGIN {
        while ((getline < map) > 0) {
            ip=$1; dom=$2
            ipdom[ip]=dom
        }
        close(map)
    }

    function is_private(ip) {
        return (ip ~ /^10\./ || ip ~ /^192\.168\./ || ip ~ /^172\.(1[6-9]|2[0-9]|3[0-1])\./)
    }

    {
        line=$0
        ips=""

        # IPv4
        while (match(line, /([0-9]{1,3}\.){3}[0-9]{1,3}/)) {
            ip=substr(line, RSTART, RLENGTH)
            ips = ips ip " "
            line = substr(line, RSTART+RLENGTH)
        }

        # Full IPv6 (8 groups only)
        line=$0
        while (match(line, /[0-9A-Fa-f]{4}(:[0-9A-Fa-f]{4}){7}/)) {
            ip = substr(line, RSTART, RLENGTH)
            sub(/%.*/, "", ip)
            ips = ips ip " "
            line = substr(line, RSTART + RLENGTH)
        }

        # Annotation
        ann=""
        split(ips, arr)
        for (i in arr) {
            ip=arr[i]
            if (ip in ipdom) ann = ann " [DOMAIN:" ipdom[ip] "]"
        }

        # Signature extraction
        if (match($0, /\[\*\*\].*\[\*\*\]/)) {
            sig=substr($0, RSTART, RLENGTH)
            sigcount[sig]++
        }

        # External summary
        rawts=$1
        split(rawts, t, "-")
        split(t[1], d, "/")
        ts = d[3] "-" d[1] "-" d[2] " " substr(t[2],1,5)

        src=$(NF-2)
        dst=$NF
        split(src, s, ":")
        split(dst, d2, ":")

        srcip=s[1]; dstip=d2[1]

        if (!is_private(srcip)) ipport=src
        else if (!is_private(dstip)) ipport=dst
        else ipport=""

        if (ipport != "") {
            cnt[ipport]++
            if (!(ipport in first)) first[ipport]=ts
            last[ipport]=ts
        }

        print $0 ann >> "'"$ANNOTATED"'"
    }

    END {
        for (s in sigcount)
            print sigcount[s], s >> "'"$SIGS"'"

        for (i in cnt)
            print i "|" cnt[i] "|" first[i] "|" last[i] >> "'"$DST"'"
    }
'

# -----------------------------
# Signature summary
# -----------------------------
SIG_SUMMARY=$(sort -nr "$SIGS" | mawk '{print $0}')

# -----------------------------
# External summary
# -----------------------------
DST_SUMMARY=$(sort -t"|" -k3,3 "$DST" \
| mawk -F"|" '{
    printf "%-22s %-8s %-20s %-20s\n", $1, $2, $3, $4
}')

# -----------------------------
# Domain list
# -----------------------------
FAST_IPS=$(mawk '{
    while (match($0, /([0-9]{1,3}\.){3}[0-9]{1,3}/)) {
        print substr($0, RSTART, RLENGTH)
        $0 = substr($0, RSTART+RLENGTH)
    }
    while (match($0, /[0-9A-Fa-f]{4}(:[0-9A-Fa-f]{4}){7}/)) {
        print substr($0, RSTART, RLENGTH)
        $0 = substr($0, RSTART+RLENGTH)
    }
}' "$ANNOTATED" | sort -u)

DOMAINS=""
for ip in "${!IP_TO_DOMAIN[@]}"; do
    if printf "%s\n" "$FAST_IPS" | grep -Fxq "$ip"; then
        dom="${IP_TO_DOMAIN[$ip]}"
        DOMAINS+="Domain: $dom
Resolved/seen IPs: $ip

"
    fi
done

# -----------------------------
# Build final email
# -----------------------------
EMAIL=""

if [[ -n "$DOMAINS" ]]; then
EMAIL+="
---------------------------------------------------
Non-Allowed Domains
---------------------------------------------------
$DOMAINS
"
fi

if [[ -n "$SIG_SUMMARY" ]]; then
EMAIL+="
---------------------------------------------------
Suricata Signatures
---------------------------------------------------
$SIG_SUMMARY

"
fi

if [[ -n "$DST_SUMMARY" ]]; then
EMAIL+="
---------------------------------------------------
External Summary
---------------------------------------------------
$DST_SUMMARY

"
fi

ANNOTATED_REPORT=$(<"$ANNOTATED")

if [[ -n "$ANNOTATED_REPORT" ]]; then
EMAIL+="
---------------------------------------------------
Suricata Report
---------------------------------------------------
$ANNOTATED_REPORT

"
fi

echo "$EMAIL"

rm -f "$TMPMAP" "$ANNOTATED" "$SIGS" "$DST"
