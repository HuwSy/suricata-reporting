#!/bin/bash

FAST_LOG="/var/log/suricata/fast.log"
HOST_IP=$(hostname -I | awk '{print $1}')
DB="/var/lib/suricata-allowed-dns.db"

declare -A NON_ALLOWED_MAP
ALLOWED_IPS=""

# -----------------------------
# IP validators
# -----------------------------
is_ipv4() {
    [[ "$1" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]
}

is_ipv6() {
    [[ "$1" =~ ^([0-9a-fA-F]{0,4}:){1,7}[0-9a-fA-F]{0,4}$ || "$1" =~ :: ]]
}

# -----------------------------
# Add mapping from DB
# -----------------------------
add_mapping() {
    local domain="$1"
    local ip="$2"
    local allowed="$3"

    [[ -z "$domain" || -z "$ip" ]] && return
    [[ "$ip" == "$HOST_IP" ]] && return

    if [[ "$allowed" = "1" ]]; then
        ALLOWED_IPS+="$ip"$'\n'
    else
        NON_ALLOWED_MAP["$domain"]+="$ip "
    fi
}

# -----------------------------
# 1) Load DNS info from DB
#    DB format: HOST|FLAG|IP|START|EXPIRY|EXPIRED
# -----------------------------
now=$(date +%s)

if [[ -s "$DB" ]]; then
    while IFS='|' read -r host flag ip start expiry expired; do
        [[ -n "$host" ]] || continue

        if ! is_ipv4 "$ip" && ! is_ipv6 "$ip"; then
            continue
        fi

        add_mapping "$host" "$ip" "$flag"
    done < "$DB"
fi

# -----------------------------
# 2) Read fast.log into memory
# -----------------------------
FAST_CONTENT=""
if [[ -s "$FAST_LOG" ]]; then
    cp "$FAST_LOG" "$FAST_LOG.o"
    : > "$FAST_LOG"
    FAST_CONTENT=$(cat "$FAST_LOG.o")
    cat "$FAST_LOG.o" >> "$FAST_LOG.old"
fi

# -----------------------------
# 3) Filter out allowed IPs (in-memory)
# -----------------------------
DNS_IPS=$(printf "%s" "$ALLOWED_IPS" | sed '/^$/d' | sort -u || true)

if [[ -n "$DNS_IPS" ]]; then
    REPORT=$(printf "%s\n" "$FAST_CONTENT" | grep -vFf <(printf "%s" "$DNS_IPS") || true)
else
    REPORT="$FAST_CONTENT"
fi

# -----------------------------
# 4) Annotate REPORT with domain info
# -----------------------------
ANNOTATED_REPORT=""

while IFS= read -r line; do
    [[ -z "$line" ]] && continue

    ips_in_line=$(echo "$line" \
        | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}|([0-9a-fA-F]{1,4}:){1,7}[0-9a-fA-F]{1,4}|::[0-9a-fA-F]{1,4}|[0-9a-fA-F]{1,4}::' \
        | sort -u || true)

    annotation=""

    for ip in $ips_in_line; do
        for domain in "${!NON_ALLOWED_MAP[@]}"; do
            if [[ " ${NON_ALLOWED_MAP[$domain]} " == *" $ip "* ]]; then
                annotation+=" [DOMAIN:$domain]"
            fi
        done
    done

    ANNOTATED_REPORT+="$line$annotation"$'\n'
done <<< "$REPORT"

# -----------------------------
# 5) Build DOMAINS list
# -----------------------------
FAST_IPS=$(printf "%s\n" "$REPORT" \
    | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}|([0-9a-fA-F]{1,4}:){1,7}[0-9a-fA-F]{1,4}|::[0-9a-fA-F]{1,4}|[0-9a-fA-F]{1,4}::' \
    | sort -u || true)

DOMAINS=""

for domain in "${!NON_ALLOWED_MAP[@]}"; do
    domain_ips=$(printf "%s" "${NON_ALLOWED_MAP[$domain]}" \
        | tr ' ' '\n' | sed '/^$/d' | sort -u || true)

    match_found=false
    for ip in $domain_ips; do
        if printf "%s\n" "$FAST_IPS" | grep -Fxq "$ip"; then
            match_found=true
            break
        fi
    done

    if $match_found; then
        DOMAINS+="Domain: $domain
Resolved/seen IPs: ${NON_ALLOWED_MAP[$domain]}

"
    fi
done

# -----------------------------
# 6) Build counted signature summary
# -----------------------------
SIG_SUMMARY=$(
    printf "%s\n" "$ANNOTATED_REPORT" \
    | awk '
        {
            s = index($0, "[**]")
            if (s == 0) next
            e = index(substr($0, s + 4), "[**]")
            if (e == 0) next
            e = s + 4 + e + 2
            sig = substr($0, s, e - s + 1)
            print sig
        }
    ' \
    | sort \
    | uniq -c \
    | sed 's/^ *//'
)

# -----------------------------
# Email/report output
# -----------------------------
EMAIL=""

if [ -n "$DOMAINS" ]; then
    EMAIL+="
---------------------------------------------------
Non-Allowed Domains
---------------------------------------------------
$DOMAINS
"
fi

if [ -n "$SIG_SUMMARY" ]; then
    EMAIL+="
---------------------------------------------------
Suricata Signatures
---------------------------------------------------
$SIG_SUMMARY

"
fi

if [ -n "$ANNOTATED_REPORT" ]; then
    EMAIL+="
---------------------------------------------------
Suricata Report
---------------------------------------------------
$ANNOTATED_REPORT

"
fi

echo "$EMAIL"
