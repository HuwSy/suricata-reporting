#!/bin/sh

OUTPUT="/var/lib/suricata-variables-docker.yaml"

###############################################
# 1. Collect IPv4 + IPv6 addresses
###############################################

HOST_IPv4=$(
    ip -4 -o addr show scope global \
    | grep -vE 'docker0|br-|veth' \
    | awk '/inet / {print $4}' \
    | cut -d/ -f1
)

HOST_IPv6=$(
    ip -6 -o addr show scope global \
    | grep -vE 'docker0|br-|veth' \
    | awk '/inet6 / {print $4}' \
    | cut -d/ -f1
)

###############################################
# 2. Collect network CIDRs
###############################################

HOME_NETS4=$(ip -o -f inet addr show scope global \
    | grep -vE 'docker0|br-|veth' \
    | awk '{print $4}')

HOME_NETS6=$(ip -o -f inet6 addr show scope global \
    | grep -vE 'docker0|br-|veth' \
    | awk '{print $4}')

###############################################
# 3. Collect Docker network CIDRs
###############################################

DOCKER_NETS=$(docker network inspect $(docker network ls -q) | awk -F'"' '/"Subnet"/ {print $4}')

###############################################
# 4. Write HOME_NET and HOST_IP
###############################################

: > "$OUTPUT"
printf "%s\n---\n" "%YAML 1.1" >> "$OUTPUT"

# HOME_NET
printf "HOME_NET: \"[%s]\"\n" "$(
  echo $HOME_NETS4" "$HOME_NETS6 | sed 's/ /,/g' | sed 's/^,//' | sed 's/,$//' | sed 's/,,/,/g'
)" >> "$OUTPUT"

# KNOWN_NET
printf "KNOWN_NET: \"[%s]\"\n" "$(
  echo $HOME_NETS4" "$HOME_NETS6" "$DOCKER_NETS | sed 's/ /,/g' | sed 's/^,//' | sed 's/,$//' | sed 's/,,/,/g'
)" >> "$OUTPUT"

# SRV_IP
printf "SRV_IP: \"[%s]\"\n" "$(
  echo $HOST_IPv4" "$HOST_IPv6 | sed 's/ /,/g' | sed 's/^,//' | sed 's/,$//' | sed 's/,,/,/g'
)" >> "$OUTPUT"

# HOST_IP
printf "HOST_IP: \"[%s]\"\n" "$(
  echo $HOST_IPv4" "$HOST_IPv6" "$DOCKER_NETS | sed 's/ /,/g' | sed 's/^,//' | sed 's/,$//' | sed 's/,,/,/g'
)" >> "$OUTPUT"

###############################################
# 5. Resolve each expected container
###############################################

for cname in "$@"; do
  # Sanitize: keep only A–Z, a–z, 0–9, _
  safe_name=$(printf "%s" "$cname" | tr -cd 'A-Za-z0-9_')
  [ -z "$safe_name" ] && continue

  # Find matching container (running or stopped)
  real_container=$(docker ps -a --format '{{.Names}}' | grep -Fx "$cname")

  if [ -n "$real_container" ]; then
    # Extract first non-empty IP from any network
    cip=$(docker inspect "$real_container" | awk -F'"' '/"IPAddress"/ { if ($4 != "") { print $4; exit } }')

    if [ -n "$cip" ]; then
      printf "%s: \"[%s]\"\n" "$safe_name" "$cip" >> "$OUTPUT"
      continue
    fi
  fi

  # Fallback if container missing or no IP
  printf "%s: \"[127.0.0.1]\"\n" "$safe_name" >> "$OUTPUT"
done
