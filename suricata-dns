#!/bin/bash

# files
DOMAINS="/etc/suricata/allowed_domains.list"
DNS_LOG="/var/log/suricata/dns.log"
DB="/var/lib/suricata-allowed-dns.db"
RULE="/var/lib/suricata-allowed-ips.rules"
HOSTS="/var/lib/suricata-allowed-hosts.yaml"

# -d to daemonise
# all other args will be turned into hosts variables and use docker ip where found
ARGS="$@"
DAEMON=0

# overrun ttl by, and retain dns log in db for
GRACE=60
RETENTION=$((7 * 24 * 3600))

# in-memory DB: key = "IP|HOST", value = "HOST|FLAG|IP|START|EXPIRY|EXPIRED"
declare -A DB_MAP
declare -a ALLOWED

# ensure file and cache if possible
touch "$DB"
vmtouch -t "$DB" "$DNS_LOG" "$RULE" "$HOSTS" || true

# start restart suricata
start_restart() {
    printf "[DEBUG] %s\n" "Restarting suricata" >&2
    if ! suricata -c /etc/suricata/suricata*.yaml -T >/dev/null 2>&1; then
        printf "[DEBUG] %s\n" "Invalid file to restart" >&2
        return
    fi
    if ! suricatasc -c reload-rules >/dev/null 2>&1; then
        systemctl restart suricata
    fi
}

# Ensure minimal variables and rules for suricata startup without errors
MINIMAL=$'%YAML 1.1\n---\nHOME_NET: "[127.0.0.1/16]"\nKNOWN_NET: "[127.0.0.1/16]"\nSRV_IP: "[127.0.0.1]"\nHOST_IP: "[127.0.0.1]"\n'
for arg in "$ARGS"; do
    if [ "$arg" = "-d" ]; then
        DAEMON=1
    else
        safe_name=$(printf "%s" "$arg" | tr -cd 'A-Za-z0-9_')
        MINIMAL+=$safe_name
        MINIMAL+=$': "[127.0.0.1]"\n'
    fi
done

if [ ! -s "$HOSTS" ]; then
    printf "%s" "$MINIMAL" > "$HOSTS"
    start_restart
fi
if [ ! -s "$RULE" ]; then
    echo "pass ip 127.0.0.1 any -> 127.0.0.1 any (msg:\"Pending dns query\"; sid:9990000; rev:1;)" > "$RULE"
    start_restart
fi

less_regular_jobs() {
    printf "[DEBUG] %s\n" "Loading allowed" >&2
    mapfile -t ALLOWED < "$DOMAINS"

    printf "[DEBUG] %s\n" "Collecting variables" >&2
    HOST_IPv4=$(
        ip -4 -o addr show scope global \
        | grep -vE 'docker0|br-|veth' \
        | awk '/inet / {print $4}' \
        | cut -d/ -f1
    )
    
    HOST_IPv6=$(
        ip -6 -o addr show scope global \
        | grep -vE 'docker0|br-|veth' \
        | awk '/inet6 / {print $4}' \
        | cut -d/ -f1
    )

    [ -z "$HOST_IPv4" ] && HOST_IPv4="127.0.0.1"
    
    HOME_NETS4=$(ip -o -f inet addr show scope global \
        | grep -vE 'docker0|br-|veth' \
        | awk '{print $4}')
    
    HOME_NETS6=$(ip -o -f inet6 addr show scope global \
        | grep -vE 'docker0|br-|veth' \
        | awk '{print $4}')
    
    [ -z "$HOME_NETS4" ] && HOME_NETS4="127.0.0.1/16"

    DOCKER_NETS=$(docker network inspect $(docker network ls -q) | awk -F'"' '/"Subnet"/ {print $4}')

    [ -z "$DOCKER_NETS" ] && DOCKER_NETS="127.0.0.1/16"

    local variables

    variables=$'%YAML 1.1\n---\n'
    # HOME_NET
    variables+="HOME_NET: \"[$(
      echo "$HOME_NETS4" "$HOME_NETS6" \
        | sed 's/ /,/g; s/^,//; s/,$//; s/,,/,/g'
    )]\""$'\n'
    
    # KNOWN_NET
    variables+="KNOWN_NET: \"[$(
      echo "$HOME_NETS4" "$HOME_NETS6" "$DOCKER_NETS" \
        | sed 's/ /,/g; s/^,//; s/,$//; s/,,/,/g'
    )]\""$'\n'
    
    # SRV_IP
    variables+="SRV_IP: \"[$(
      echo "$HOST_IPv4" "$HOST_IPv6" \
        | sed 's/ /,/g; s/^,//; s/,$//; s/,,/,/g'
    )]\""$'\n'
    
    # HOST_IP
    variables+="HOST_IP: \"[$(
      echo "$HOST_IPv4" "$HOST_IPv6" "$DOCKER_NETS" \
        | sed 's/ /,/g; s/^,//; s/,$//; s/,,/,/g'
    )]\""$'\n'

    for cname in "$ARGS"; do
      # skip for -d daemonise
      [ "$cname" = "-d" ] && continue

      # Sanitize: keep only A–Z, a–z, 0–9, _
      safe_name=$(printf "%s" "$cname" | tr -cd 'A-Za-z0-9_')
      [ -z "$safe_name" ] && continue
    
      printf "[DEBUG] %s\n" "Getting $cname" >&2

      # Find matching container (running or stopped)
      real_container=$(docker ps -a --format '{{.Names}}' | grep -Fx "$cname")
    
      if [ -n "$real_container" ]; then
        # Extract first non-empty IP from any network
        cip=$(docker inspect "$real_container" | awk -F'"' '/"IPAddress"/ { if ($4 != "") { print $4; exit } }')
    
        if [ -n "$cip" ]; then
          variables+=$(printf "%s: \"[%s]\"\n" "$safe_name" "$cip")
          continue
        fi
      fi
    
      # Fallback if container missing or no IP
      variables+=$(printf "%s: \"[127.0.0.1]\"\n" "$safe_name")
    done

    local current_variables=""
    [ -f "$HOSTS" ] && current_variables=$(cat "$HOSTS")
    if [[ "$variables" != "$current_variables" ]]; then
        printf "%s\n" "$variables" > "$HOSTS"
        start_restart
    fi
}

is_allowed() {
    local host="$1"
    local d
    for d in "${ALLOWED[@]}"; do
        [[ "$host" == "$d" ]] && return 0
        [[ "$host" == *".$d" ]] && return 0
    done
    return 1
}

load_db() {
    printf "[DEBUG] %s\n" "Load DB" >&2
    local now cutoff host flag ip start expiry expired key
    now=$(date +%s)
    cutoff=$((now - RETENTION))

    while IFS="|" read -r host flag ip start expiry expired; do
        [ -z "$host" ] && continue
        [[ "$expiry" =~ ^[0-9]+$ ]] || continue
        [ "$expiry" -lt "$cutoff" ] && continue

        key="${ip}|${host}"
        DB_MAP["$key"]="${host}|${flag}|${ip}|${start}|${expiry}|${expired}"
    done < "$DB"
}

write_db() {
    printf "[DEBUG] %s\n" "Write DB" >&2
    local now cutoff key val host flag ip start expiry expired
    now=$(date +%s)
    cutoff=$((now - RETENTION))
    local new_db=""

    for key in "${!DB_MAP[@]}"; do
        val=${DB_MAP["$key"]}
        IFS="|" read -r host flag ip start expiry expired <<< "$val"
        [ -z "$host" ] && continue
        [[ "$expiry" =~ ^[0-9]+$ ]] || continue
        [ "$expiry" -lt "$cutoff" ] && continue

        new_db+="${host}|${flag}|${ip}|${start}|${expiry}|${expired}\n"
    done

    local current_db=""
    [ -f "$DB" ] && current_db=$(cat "$DB")
    if [[ "$new_db" != "$current_db" ]]; then
        printf "%b" "$new_db" > "$DB"
    fi
}

build_out_rules() {
    printf "[DEBUG] %s\n" "Build rules" >&2
    local now key val host flag ip start expiry expired
    now=$(date +%s)
    local ips_buf=""
    local rules_buf=""
    local sid=9990000

    for key in "${!DB_MAP[@]}"; do
        val=${DB_MAP["$key"]}
        IFS="|" read -r host flag ip start expiry expired <<< "$val"
        [ -z "$host" ] && continue
        [[ "$expiry" =~ ^[0-9]+$ ]] || continue
        [ "$expiry" -le "$now" ] && continue
        [ "$flag" -ne 1 ] && continue

        case "$ip" in
            *.*.*.*|*:*:*) ;;
            *) continue ;;
        esac

        ips_buf+="${ip}\n"

        rules_buf+="pass tcp any any -> $ip 443 (msg:\"Allowed 443 via DNS to $host\"; sid:$sid; rev:1;)\n"
        ((sid++))
        rules_buf+="pass tcp $ip 443 -> any any (msg:\"Allowed 443 via DNS to $host (established)\"; flow:from_server,established; sid:$sid; rev:1;)\n"
        ((sid++))
        rules_buf+="pass tcp any any -> $ip 80 (msg:\"Allowed 80 via DNS to $host\"; sid:$sid; rev:1;)\n"
        ((sid++))
        rules_buf+="pass tcp $ip 80 -> any any (msg:\"Allowed 80 via DNS to $host (established)\"; flow:from_server,established; sid:$sid; rev:1;)\n"
        ((sid++))
    done

    local new_rule
    if [ -n "$rules_buf" ]; then
        new_rule=$(printf "%b" "$rules_buf" | sed '/^$/d' | sort)
    else
        new_rule="pass ip 127.0.0.1 any -> 127.0.0.1 any (msg:\"Pending dns query\"; sid:9990000; rev:1;)"
    fi

    local current_rule=""
    [ -f "$RULE" ] && current_rule=$(cat "$RULE")
    if [[ "$new_rule" != "$current_rule" ]]; then
        printf "%s\n" "$new_rule" > "$RULE"
        start_restart
    fi
}

process_dns_log() {
    printf "[DEBUG] %s\n" "Collecting DNS" >&2
    # safe rotation: copy + truncate
    DNS_CONTENT=""
    if [ -s "$DNS_LOG" ]; then
        DNS_CONTENT=$(<"$DNS_LOG")
        : > "$DNS_LOG"
        printf "%s\n" "$DNS_CONTENT" >> "$DNS_LOG.old"
    else
        return
    fi

    local now midnight ts host ip ttl token prev
    now=$(date +%s)
    midnight=$(date -d "$(date +%Y-%m-%d) 00:00:00" +%s)

    while IFS= read -r line; do
        clean_line=$(printf "%s" "$line" | tr -d '[]*')

        case "$clean_line" in
            *" Response "*)
                case "$clean_line" in
                    *" A "*|*" AAAA "*) ;;
                    *) continue ;;
                esac
                ;;
            *) continue ;;
        esac

        host=""
        ip=""
        ttl=""
        ts=""
        prev=""

        for token in $clean_line; do
            if [ -z "$ts" ]; then
                ts="$token"
                prev="TS"
                continue
            fi

            if [ "$prev" = "TTL" ]; then
                case "$token" in
                    ''|*[!0-9]*) ;;
                    *) ttl="$token" ;;
                esac
            fi

            if [ -z "$host" ]; then
                case "$token" in
                    *\.[A-Za-z]*)
                        host="$token"
                        ;;
                esac
            fi

            if [ -z "$ip" ]; then
                case "$token" in
                    [0-9]*.[0-9]*.[0-9]*.[0-9]*)
                        ip="$token"
                        ;;
                esac
            fi

            if [ -z "$ip" ]; then
                case "$token" in
                    *:*:*)
                        ip="${token,,}"
                        ;;
                esac
            fi

            prev="$token"

            if [ -n "$host" ] && [ -n "$ip" ] && [ -n "$ttl" ]; then
                break
            fi
        done

        [ -z "$host" ] && continue
        [ -z "$ip" ] && continue
        [ -z "$ttl" ] && continue

        timepart=${ts#*-}
        h=${timepart:0:2}
        m=${timepart:3:2}
        s=${timepart:6:2}

        case "$h$m$s" in
            *[!0-9]*) continue ;;
        esac

        seconds_since_midnight=$((10#$h*3600 + 10#$m*60 + 10#$s))
        start=$((midnight + seconds_since_midnight))
        expiry=$((start + ttl + GRACE))

        flag=0
        is_allowed "$host" && flag=1

        expired=0

        key="${ip}|${host}"
        DB_MAP["$key"]="${host}|${flag}|${ip}|${start}|${expiry}|${expired}"
    done <<< "$DNS_CONTENT"
}

main_loop() {
    printf "[DEBUG] %s\n" "Startup" >&2
    load_db
    local count=0
    while true; do
        if (( count == 0 )); then
            less_regular_jobs
        fi
        process_dns_log
        build_out_rules
        if [ "$DAEMON" = "0" ]; then
            printf "[DEBUG] %s\n" "Not daemon, ending" >&2
            break
        fi
        if (( count >= 600 )); then
            write_db
            count=0
        fi
        ((count++))
        sleep 6
    done
}

main_loop
