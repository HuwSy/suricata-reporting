#!/bin/bash

DNS_LOG="/var/log/suricata/dns.log"
DOMAINS="/etc/suricata/allowed_domains.list"
DB="/var/run/suricata-allowed-dns.db"
OUT="/var/run/suricata-allowed-ips.list"
RULE="/var/run/suricata-allowed-ips.rules"

GRACE=3600
RETENTION=$((30 * 24 * 3600))

NOW=$(date +%s)
CUTOFF=$((NOW - RETENTION))

touch "$DB"
touch "$OUT"
[ ! -s "$RULE" ] && echo "pass ip 127.0.0.1 any -> 127.0.0.1 any (msg:\"Pending dns query\"; sid:9990000; rev:1;)" > "$RULE"

canon_ipv4() {
    local ip="$1"
    local o1 o2 o3 o4
    IFS='.' read -r o1 o2 o3 o4 <<< "$ip" || return 1
    for o in "$o1" "$o2" "$o3" "$o4"; do
        [[ "$o" =~ ^[0-9]+$ ]] || return 1
        (( o >= 0 && o <= 255 )) || return 1
    done
    printf "%d.%d.%d.%d" "$o1" "$o2" "$o3" "$o4"
}

strip_scope_id() {
    printf "%s" "${1%%%*}"
}

canon_ipv6() {
    local t="$1"
    for _ in 1 2 3 4; do
        t=${t//:0/:}
        t=${t//:::/::}
    done
    printf '%s\n' "$t"
}

mapfile -t ALLOWED < "$DOMAINS"

is_allowed() {
    local host="$1"
    for d in "${ALLOWED[@]}"; do
        [[ "$host" == "$d" ]] && return 0
        [[ "$host" == *".$d" ]] && return 0
    done
    return 1
}

declare -A IP_HOST_EXP
declare -A IP_HOST_FLAG

while IFS="|" read -r IP HOST EXP FLAG; do
    [[ -z "$IP" ]] && continue
    (( EXP >= CUTOFF )) || continue
    key="${IP}|${HOST}"
    IP_HOST_EXP["$key"]="$EXP"
    IP_HOST_FLAG["$key"]="$FLAG"
done < "$DB"

mv "$DNS_LOG" "$DNS_LOG.old"
touch "$DNS_LOG"

grep "Response" "$DNS_LOG.old" | grep -e " A " -e " AAAA " | while IFS= read -r line; do
    clean_line=$(printf "%s" "$line" | tr -d '[]*')

    HOST=""
    IP=""
    TTL=""
    prev=""

    for token in $clean_line; do
        # Skip date on 1st column
        if [ "$prev" = "" ]; then
            prev="Date"
            continue
        fi

        # Host extraction (domain-like token)
        if [ -z "$HOST" ]; then
            case "$token" in
                *\.[A-Za-z]*)
                    HOST="$token"
                    ;;
            esac
        fi

        # TTL extraction
        if [ "$prev" = "TTL" ]; then
            case "$token" in
                ''|*[!0-9]*) ;;
                *) TTL="$token" ;;
            esac
        fi
        prev="$token"

        # IPv4 extraction (first A record IP only)
        if [ -z "$IP" ]; then
            case "$token" in
                [0-9]*\.[0-9]*\.[0-9]*\.[0-9]*)
                    IP="$(canon_ipv4 "$token")"
                    ;;
            esac
        fi

        # IPv6 extraction (first AAAA record IP only)
        if [ -z "$IP" ]; then
            case "$token" in
                [0-9a-fA-F]*:*:*)
                    IP="$(canon_ipv6 "$token")"
                    ;;
            esac
        fi

        if [ -n "$HOST" ] && [ -n "$IP" ] && [ -n "$TTL" ]; then
            break
        fi
    done

    [ -z "$HOST" ] && continue
    [ -z "$IP" ] && continue
    [ -z "$TTL" ] && continue

    EXPIRY=$((NOW + TTL + GRACE))

    if is_allowed "$HOST"; then FLAG=1; else FLAG=0; fi

    key="${IP}|${HOST}"
    IP_HOST_EXP["$key"]="$EXPIRY"
    IP_HOST_FLAG["$key"]="$FLAG"
done

NEW_DB=""
for key in "${!IP_HOST_EXP[@]}"; do
    IFS="|" read -r IP HOST <<< "$key"
    EXP="${IP_HOST_EXP[$key]}"
    FLAG="${IP_HOST_FLAG[$key]}"
    NEW_DB+="${IP}|${HOST}|${EXP}|${FLAG}\n"
done

CURRENT_DB=$(cat "$DB")
if [[ "$NEW_DB" != "$CURRENT_DB" ]]; then
    printf "%b" "$NEW_DB" > "$DB"
fi

NEW_OUT=""
for key in "${!IP_HOST_EXP[@]}"; do
    IFS="|" read -r IP HOST <<< "$key"
    EXP="${IP_HOST_EXP[$key]}"
    FLAG="${IP_HOST_FLAG[$key]}"
    if (( FLAG == 1 && EXP > NOW )); then
        NEW_OUT+="${IP}\n"
    fi
done

NEED_RELOAD=0

CURRENT_OUT=$(cat "$OUT")
if [[ "$NEW_OUT" != "$CURRENT_OUT" ]]; then
    printf "%b" "$NEW_OUT" > "$OUT"
    NEED_RELOAD=1
fi

NEW_RULE=""
C=9990000
for key in "${!IP_HOST_EXP[@]}"; do
    IFS="|" read -r IP HOST <<< "$key"
    EXP="${IP_HOST_EXP[$key]}"
    FLAG="${IP_HOST_FLAG[$key]}"
    if (( FLAG == 1 && EXP > NOW )); then
        NEW_RULE+="pass ip any any -> $IP 443 (msg:\"Allowed 443 via DNS resolution\"; sid:$C; rev:1;)\n"
        ((C++))
        NEW_RULE+="pass ip $IP 443 -> any any (msg:\"Allowed 443 via DNS resolution (established)\"; flow:from_server,established; sid:$C; rev:1;)\n"
        ((C++))
        NEW_RULE+="pass ip any any -> $IP 80 (msg:\"Allowed 80 via DNS resolution\"; sid:$C; rev:1;)\n"
        ((C++))
        NEW_RULE+="pass ip $IP 80 -> any any (msg:\"Allowed 80 via DNS resolution (established)\"; flow:from_server,established; sid:$C; rev:1;)\n"
        ((C++))
    fi
done

CURRENT_RULE=$(cat "$RULE")
if [[ "$NEW_RULE" != "$CURRENT_RULE" ]]; then
    printf "%b" "$NEW_RULE" > "$RULE"
    NEED_RELOAD=1
fi

if [ "$NEED_RELOAD" = "1" ]; then
    if suricatasc -c reload-rules >/dev/null 2>&1; then
        echo "Rules reloaded"
    else
        echo "Reload not supported, restarting Suricata"
        systemctl restart suricata
    fi
fi
