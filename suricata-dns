#!/bin/bash

DNS_LOG="/var/log/suricata/dns.log"
DOMAINS="/etc/suricata/allowed_domains.list"
DB="/var/lib/suricata-allowed-dns.db"
OUT="/var/lib/suricata-allowed-ips.list"
RULE="/var/lib/suricata-allowed-ips.rules"

DAEMON=0
[ "$1" = "-d" ] && DAEMON=1

GRACE=60
RETENTION=$((7 * 24 * 3600))

start_restart() {
    if [ "$1" = "1" ]; then
        if ! suricata -c /etc/suricata/suricata*.yaml -T >/dev/null 2>&1; then
            return
        fi
        if ! suricatasc -c reload-rules >/dev/null 2>&1; then
            systemctl restart suricata
        fi
    fi
}

touch "$DB"

needs_start=0
if [ ! -s "$OUT" ]; then
    echo "127.0.0.1" > "$OUT"
    needs_start=1
fi
if [ ! -s "$RULE" ]; then
    echo "pass ip 127.0.0.1 any -> 127.0.0.1 any (msg:\"Pending dns query\"; sid:9990000; rev:1;)" > "$RULE"
    needs_start=1
fi

# cache if possible
vmtouch -t "$DB" "$DNS_LOG" "$RULE" "$OUT" || true

start_restart $needs_start

# --- load allowed domains once ---
mapfile -t ALLOWED < "$DOMAINS"

is_allowed() {
    local host="$1"
    local d
    for d in "${ALLOWED[@]}"; do
        [[ "$host" == "$d" ]] && return 0
        [[ "$host" == *".$d" ]] && return 0
    done
    return 1
}

# in-memory DB: key = "IP|HOST", value = "HOST|FLAG|IP|START|EXPIRY|EXPIRED"
declare -A DB_MAP

load_db() {
    local now cutoff host flag ip start expiry expired key
    now=$(date +%s)
    cutoff=$((now - RETENTION))

    while IFS="|" read -r host flag ip start expiry expired; do
        [ -z "$host" ] && continue
        [[ "$expiry" =~ ^[0-9]+$ ]] || continue
        [ "$expiry" -lt "$cutoff" ] && continue

        key="${ip}|${host}"
        DB_MAP["$key"]="${host}|${flag}|${ip}|${start}|${expiry}|${expired}"
    done < "$DB"
}

write_db() {
    local now cutoff key val host flag ip start expiry expired
    now=$(date +%s)
    cutoff=$((now - RETENTION))
    local new_db=""

    for key in "${!DB_MAP[@]}"; do
        val=${DB_MAP["$key"]}
        IFS="|" read -r host flag ip start expiry expired <<< "$val"
        [ -z "$host" ] && continue
        [[ "$expiry" =~ ^[0-9]+$ ]] || continue
        [ "$expiry" -lt "$cutoff" ] && continue

        new_db+="${host}|${flag}|${ip}|${start}|${expiry}|${expired}\n"
    done

    local current_db=""
    [ -f "$DB" ] && current_db=$(cat "$DB")
    if [[ "$new_db" != "$current_db" ]]; then
        printf "%b" "$new_db" > "$DB"
    fi
}

build_out_and_rules() {
    local now key val host flag ip start expiry expired
    now=$(date +%s)
    local ips_buf=""
    local rules_buf=""
    local sid=9990000

    for key in "${!DB_MAP[@]}"; do
        val=${DB_MAP["$key"]}
        IFS="|" read -r host flag ip start expiry expired <<< "$val"
        [ -z "$host" ] && continue
        [[ "$expiry" =~ ^[0-9]+$ ]] || continue
        [ "$expiry" -le "$now" ] && continue
        [ "$flag" -ne 1 ] && continue

        case "$ip" in
            *.*.*.*|*:*:*) ;;
            *) continue ;;
        esac

        ips_buf+="${ip}\n"

        rules_buf+="pass ip any any -> $ip 443 (msg:\"Allowed 443 via DNS to $host\"; sid:$sid; rev:1;)\n"
        ((sid++))
        rules_buf+="pass ip $ip 443 -> any any (msg:\"Allowed 443 via DNS to $host (established)\"; flow:from_server,established; sid:$sid; rev:1;)\n"
        ((sid++))
        rules_buf+="pass ip any any -> $ip 80 (msg:\"Allowed 80 via DNS to $host\"; sid:$sid; rev:1;)\n"
        ((sid++))
        rules_buf+="pass ip $ip 80 -> any any (msg:\"Allowed 80 via DNS to $host (established)\"; flow:from_server,established; sid:$sid; rev:1;)\n"
        ((sid++))
    done

    local new_out new_rule
    if [ -n "$ips_buf" ]; then
        new_out=$(printf "%b" "$ips_buf" | sed '/^$/d' | sort -u)
    else
        new_out="127.0.0.1"
    fi

    if [ -n "$rules_buf" ]; then
        new_rule=$(printf "%b" "$rules_buf" | sed '/^$/d' | sort)
    else
        new_rule="pass ip 127.0.0.1 any -> 127.0.0.1 any (msg:\"Pending dns query\"; sid:9990000; rev:1;)"
    fi

    local need_reload=0
    local current_out="" current_rule=""

    [ -f "$OUT" ] && current_out=$(cat "$OUT")
    if [[ "$new_out" != "$current_out" ]]; then
        printf "%s\n" "$new_out" > "$OUT"
        need_reload=1
    fi

    [ -f "$RULE" ] && current_rule=$(cat "$RULE")
    if [[ "$new_rule" != "$current_rule" ]]; then
        printf "%s\n" "$new_rule" > "$RULE"
        need_reload=1
    fi

    start_restart $need_reload
}

process_dns_log_once() {
    # safe rotation: copy + truncate
    DNS_CONTENT=""
    if [ -s "$DNS_LOG" ]; then
        DNS_CONTENT=$(<"$DNS_LOG")
        : > "$DNS_LOG"
        printf "%s\n" "$DNS_CONTENT" >> "$DNS_LOG.old"
    else
        return
    fi

    [ ! -s "$DNS_LOG.o" ] && return

    local now midnight ts host ip ttl token prev
    now=$(date +%s)
    midnight=$(date -d "$(date +%Y-%m-%d) 00:00:00" +%s)

    while IFS= read -r line; do
        clean_line=$(printf "%s" "$line" | tr -d '[]*')

        case "$clean_line" in
            *" Response "*)
                case "$clean_line" in
                    *" A "*|*" AAAA "*) ;;
                    *) continue ;;
                esac
                ;;
            *) continue ;;
        esac

        host=""
        ip=""
        ttl=""
        ts=""
        prev=""

        for token in $clean_line; do
            if [ -z "$ts" ]; then
                ts="$token"
                prev="TS"
                continue
            fi

            if [ "$prev" = "TTL" ]; then
                case "$token" in
                    ''|*[!0-9]*) ;;
                    *) ttl="$token" ;;
                esac
            fi

            if [ -z "$host" ]; then
                case "$token" in
                    *\.[A-Za-z]*)
                        host="$token"
                        ;;
                esac
            fi

            if [ -z "$ip" ]; then
                case "$token" in
                    [0-9]*.[0-9]*.[0-9]*.[0-9]*)
                        ip="$token"
                        ;;
                esac
            fi

            if [ -z "$ip" ]; then
                case "$token" in
                    *:*:*)
                        ip="${token,,}"
                        ;;
                esac
            fi

            prev="$token"

            if [ -n "$host" ] && [ -n "$ip" ] && [ -n "$ttl" ]; then
                break
            fi
        done

        [ -z "$host" ] && continue
        [ -z "$ip" ] && continue
        [ -z "$ttl" ] && continue

        timepart=${ts#*-}
        h=${timepart:0:2}
        m=${timepart:3:2}
        s=${timepart:6:2}

        case "$h$m$s" in
            *[!0-9]*) continue ;;
        esac

        seconds_since_midnight=$((10#$h*3600 + 10#$m*60 + 10#$s))
        start=$((midnight + seconds_since_midnight))
        expiry=$((start + ttl + GRACE))

        flag=0
        is_allowed "$host" && flag=1

        expired=0

        key="${ip}|${host}"
        DB_MAP["$key"]="${host}|${flag}|${ip}|${start}|${expiry}|${expired}"
    done <<< "$DNS_CONTENT"
}

main_loop() {
    load_db
    local count=0
    while true; do
        process_dns_log_once
        build_out_and_rules
        if [ "$DAEMON" = "0" ]; then
            break
        fi
        if (( count >= 600 )); then
            write_db
            count=0
        fi
        ((count++))
        sleep 6
    done
}

main_loop
